<Window x:Class="CertificatesManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Certificates Manager"
        Height="450"
        Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,0,0,8"
                   Text="Certificates folder" />

        <TextBox x:Name="FolderPathTextBox"
                 Grid.Row="1"
                 Grid.Column="0"
                 Margin="0,0,8,12"
                 VerticalContentAlignment="Center"
                 KeyDown="FolderPathTextBox_KeyDown"
                 LostFocus="FolderPathTextBox_LostFocus" />

        <Button Grid.Row="1"
                Grid.Column="1"
                Width="120"
                Height="30"
                VerticalAlignment="Top"
                Content="Choose folder"
                Click="ChooseFolderButton_Click" />

        <ListView x:Name="CertificatesListView"
                  Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Захищений"
                                    Width="85"
                                    DisplayMemberBinding="{Binding IsProtectedMark}" />
                    <GridViewColumn Header="RSA"
                                    Width="60"
                                    DisplayMemberBinding="{Binding IsRsaMark}" />
                    <GridViewColumn Header="Файл"
                                    Width="200"
                                    DisplayMemberBinding="{Binding FileName}" />
                    <GridViewColumn Header="ПІБ"
                                    Width="280"
                                    DisplayMemberBinding="{Binding PersonName}" />
                    <GridViewColumn Header="ІПН"
                                    Width="100"
                                    DisplayMemberBinding="{Binding Tin}" />
                </GridView>
            </ListView.View>
        </ListView>

        <StatusBar Grid.Row="3"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
